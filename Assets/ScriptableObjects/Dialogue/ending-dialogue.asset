  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 71f7f8cf7b38af34783332bb400a06b8, type: 3}
  m_Name: ending-dialogue
  m_EditorClassIdentifier: 
  characterName: You.
  characterPortrait: {fileID: 21300000, guid: f36fbf6dee429ca41a4cab3318474059, type: 3}
  lines:
  - The surgery went on for hours.
  - No pain killers and no anesthesia.
  - Just a paralyzing drug that stopped me from moving but allowed me to feel everything.
  - 'And now this is all that remains of me. '
  - I can't open my mouth and I am in so much pain I must scream.
  - I am at the bottom of the lake with all sorts of horrid creatures like myself.
  - I am disgusting.
  - It smells like rotting corpses down here. I see other creatures that I know were
    once just like me.
  - I doubt any one of them has their sanity left. I am already losing mine.
  - I will never see my family again. And even if I could...
  - They would never accept me for the horrific sea monster I was turned into.
  - This is hell.
  - No. This is so much worse.
  textSpeed: 30
  typingSound: {fileID: 8300000, guid: f5d143911732a1f43b570748ed2458a4, type: 3}
